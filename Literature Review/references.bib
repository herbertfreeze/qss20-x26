@article{welchMeasureEquityPublic2013,
  title = {A Measure of Equity for Public Transit Connectivity},
  author = {Welch, Timothy F. and Mishra, Sabyasachee},
  year = 2013,
  journal = {Journal of Transport Geography},
  volume = {33},
  number = {C},
  pages = {29--41},
  publisher = {Elsevier},
  urldate = {2026-07-21},
  abstract = {An equitable transit system can cater to the needs of captive riders and maximize transit service coverage. Historically transit equity has not considered in planning or has been an afterthought in the process; leading to the underutilization of transit and encouraging travelers to be auto dependent. In this paper, the authors propose a methodology to estimate transit equity using a number of attributes such as frequency, speed, capacity, and built environment in a multi-modal transit network. We propose a methodology to measure transit equity from a graph theoretical approach for all levels of transit service coverage integrating routes, schedules, socio-economic, demographic and spatial activity patterns.},
  langid = {english},
  keywords = {Capacity,Frequency,Graph theory,Multi-modal transit,Transit equity},
  file = {/Users/rk/Zotero/storage/99Q2EWB2/Welch and Mishra - 2013 - A measure of equity for public transit connectivity.pdf;/Users/rk/Zotero/storage/KPCX6ECB/v33y2013icp29-41.html}
}
